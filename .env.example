# Skopiuj jako .env i wklej klucz (wystarczy jeden):

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Cursor SDK (zalecane)
CURSOR_API_KEY=cursor_...
# CURSOR_MODEL=composer-2.5

# Historia ai.md przy pętli AI (patrz PRD.md — sekcja Pętla AI)
# DEBUG=false  -> tylko backend/data/ai.md (nadpisywanie)
# DEBUG=true   -> ai.md + snapshoty data/ai/ai_001.md, ai_002.md, ...
DEBUG=false
